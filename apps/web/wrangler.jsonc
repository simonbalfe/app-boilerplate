{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "app-boilerplate",
  "compatibility_date": "2025-09-27",
  "compatibility_flags": ["nodejs_compat"],
  "main": "@tanstack/react-start/server-entry",
  "assets": {
    "directory": "./dist/client"
  },
  "observability": {
    "enabled": true
  }
}
